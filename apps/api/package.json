{
  "name": "@route-helper/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node ../../scripts/require-node-20.mjs && tsx watch src/server.ts",
    "dev:once": "node ../../scripts/require-node-20.mjs && tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node ../../scripts/require-node-20.mjs && bun test ./test/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.0",
    "@route-helper/db": "workspace:*",
    "@route-helper/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "@types/node": "^22.8.7"
  }
}
