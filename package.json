{
  "name": "route-helper",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @route-helper/mobile dev",
    "dev:mobile": "bun run --filter @route-helper/mobile dev",
    "dev:api": "bun run --filter @route-helper/api dev",
    "dev:worker": "bun run --filter @route-helper/worker dev",
    "test": "bun run test:shared && bun run test:google-routes && bun run test:mobile && bun run test:api && bun run test:worker",
    "test:api": "node scripts/require-node-20.mjs && bun test apps/api/test/*.test.ts",
    "test:google-routes": "bun test packages/google-routes/test/*.test.ts",
    "test:shared": "bun test packages/shared/test/*.test.ts",
    "test:mobile": "bun test apps/mobile/test/*.test.ts",
    "test:worker": "node scripts/require-node-20.mjs && bun test apps/worker/test/*.test.ts",
    "typecheck": "bun run typecheck:all",
    "typecheck:all": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "1.3.14"
  }
}
