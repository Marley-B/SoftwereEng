{
  "name": "route-helper",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @route-helper/mobile dev",
    "dev:mobile": "bun run --filter @route-helper/mobile dev",
    "dev:api": "bun run --filter @route-helper/api dev",
    "dev:worker": "bun run --filter @route-helper/worker dev",
    "typecheck": "bun run typecheck:all",
    "typecheck:all": "bun run --filter '*' typecheck"
  }
}

