{
  "name": "route-helper",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @route-helper/api dev",
    "test": "bun run test:api && bun run test:shared",
    "test:api": "node scripts/require-node-20.mjs && bun test apps/api/test/*.test.ts",
    "test:shared": "bun test packages/shared/test/*.test.ts",
    "typecheck": "bun run typecheck:all",
    "typecheck:all": "bun run --filter '*' typecheck"
  }
}
