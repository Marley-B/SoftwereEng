{
  "name": "route-helper",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @route-helper/mobile dev",
    "dev:mobile": "bun run --filter @route-helper/mobile dev",
    "dev:api": "bun run --filter @route-helper/api dev",
    "dev:worker": "bun run --filter @route-helper/worker dev",
    "test": "bun run test:shared && bun run test:mobile && bun run test:api && bun run test:worker",
    "test:api": "bun run --filter @route-helper/api test",
    "test:shared": "bun run --filter @route-helper/shared test",
    "test:mobile": "bun run --filter @route-helper/mobile test",
    "test:worker": "bun run --filter @route-helper/worker test",
    "typecheck": "bun run typecheck:all",
    "typecheck:all": "bun run --filter '*' typecheck"
  }
}
